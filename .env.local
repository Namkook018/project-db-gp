# ===================================================
# School Management System - Environment Variables
# ===================================================

# Set to 'true' to use mock data (no GAS needed)
# Set to 'false' and provide GAS_URL to use real data
NEXT_PUBLIC_USE_MOCK=false

# Google Apps Script Web App URL
# 1. Open Google Apps Script (script.google.com)
# 2. Create new project, paste code from gas/Code.gs
# 3. Deploy > New Deployment > Web App
# 4. Set Execute as: Me, Who has access: Anyone
# 5. Copy the Web App URL here
NEXT_PUBLIC_GAS_URL=https://script.google.com/macros/s/AKfycbyPteX9RwpcXPrm0WI3AZ7vbdWqmnuiX5kN-iuPOuSdU1O5aUNEJTM4O0etVTdwlf9MUQ/exec

# Google Drive Folder IDs for Knowledge Repository
